<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= seo.meta_title || (seo.origen + ' → ' + seo.destino + ' — ' + nombreMarca) %></title>

<% if (seo.meta_description) { %>
<meta name="description" content="<%= seo.meta_description %>">
<% } %>

<meta name="robots" content="<%= seo.robots_status || 'index,follow' %>">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="<%= nombreMarca %>">
<meta property="og:title" content="<%= seo.og_title || seo.meta_title || (seo.origen + ' → ' + seo.destino) %>">
<% if (seo.og_description || seo.meta_description) { %>
<meta property="og:description" content="<%= seo.og_description || seo.meta_description %>">
<% } %>
<% if (seo.canonical_url) { %>
<meta property="og:url" content="<%= seo.canonical_url %>">
<% } %>
<% if (seo.tiene_imagen) { %>
<meta property="og:image" content="<%= BASE_URL %>/ruta-imagen/<%= seo.ruta_id %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<% } else if (tieneImagenDefecto) { %>
<meta property="og:image" content="<%= BASE_URL %>/imagen-og-defecto">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<% } %>

<!-- Twitter / X (solo si está activado en los ajustes globales) -->
<% if (twitterActivo) { %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= seo.og_title || seo.meta_title || (seo.origen + ' → ' + seo.destino) %>">
<% if (seo.og_description || seo.meta_description) { %>
<meta name="twitter:description" content="<%= seo.og_description || seo.meta_description %>">
<% } %>
<% if (seo.tiene_imagen) { %>
<meta name="twitter:image" content="<%= BASE_URL %>/ruta-imagen/<%= seo.ruta_id %>">
<% } else if (tieneImagenDefecto) { %>
<meta name="twitter:image" content="<%= BASE_URL %>/imagen-og-defecto">
<% } %>
<% } %>

<!-- Canonical -->
<% if (seo.canonical_url) { %>
<link rel="canonical" href="<%= seo.canonical_url %>">
<% } %>

<!-- Hreflang: una etiqueta por cada idioma activo de esta ruta -->
<% alternates.forEach(function(alt) { %>
<link rel="alternate" hreflang="<%= alt.lang_code %>" href="<%= BASE_URL %>/<%= alt.lang_code %>/<%= SECCIONES_TRASLADO[alt.lang_code] %>/<%= alt.slug_url %>">
<% }); %>
<!-- x-default apunta siempre a la versión en español -->
<link rel="alternate" hreflang="x-default" href="<%= BASE_URL %>/es/<%= SECCIONES_TRASLADO['es'] %>/<%= seo.slug_url %>">

<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500&family=Public+Sans:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/estilos.css">
<style>
.hero {
  min-height: 420px;
  background-color: var(--charcoal);
  background-size: cover;
  background-position: center;
  display: flex;
  flex-direction: column;
  color: var(--texto-claro);
  padding: 24px 24px 60px;
}
.hero-overlay {
  position: relative;
  background: rgba(28,24,21,0.60);
  border-radius: 16px;
  padding: 36px 32px;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
}
.nav-superior {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 900px;
  margin: 0 auto 28px;
  width: 100%;
}
.nav-links { font-size: 13px; opacity: 0.7; }
.etiqueta-ruta {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: 0.65;
  margin-bottom: 8px;
}
.titulo-ruta {
  font-size: clamp(26px, 4.5vw, 42px);
  line-height: 1.1;
  margin-bottom: 14px;
}
.titulo-ruta .acento { color: var(--terracota); }
.subtitulo-ruta {
  font-size: 15px;
  opacity: 0.85;
  max-width: 440px;
  margin-bottom: 28px;
}
.boton-reservar {
  display: inline-block;
  background: var(--terracota);
  color: white;
  font-family: 'Big Shoulders Display', sans-serif;
  font-size: 16px;
  padding: 12px 28px;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.15s;
}
.boton-reservar:hover { opacity: 0.88; }
.seccion {
  max-width: 900px;
  margin: 50px auto;
  padding: 0 24px;
}
.seccion h2 {
  font-family: 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 24px;
  margin-bottom: 18px;
  color: var(--texto-oscuro);
}
.tabla-tarifas {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.tabla-tarifas th {
  background: var(--charcoal);
  color: var(--texto-claro);
  padding: 10px 14px;
  text-align: left;
  font-weight: 500;
  font-family: 'Big Shoulders Display', sans-serif;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.tabla-tarifas td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--gris-borde);
  color: var(--texto-oscuro);
}
.tabla-tarifas tr:last-child td { border-bottom: none; }
.tabla-tarifas tr:hover td { background: var(--gris-fondo); }
.precio-fijo {
  font-weight: 500;
  font-size: 16px;
  color: var(--texto-oscuro);
}
.badge-fijo {
  background: var(--oro);
  color: var(--oro-texto);
  font-size: 11px;
  font-weight: 500;
  padding: 3px 9px;
  border-radius: 10px;
  margin-left: 8px;
}
.consultar {
  color: var(--texto-muted);
  font-style: italic;
}
.tres-columnas {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
footer {
  text-align: center;
  padding: 30px;
  color: var(--texto-muted);
  font-size: 13px;
  border-top: 1px solid var(--gris-borde);
  margin-top: 40px;
}
</style>
</head>
<body>

<div class="hero" id="hero">
  <div class="nav-superior">
    <a href="/" style="text-decoration:none;color:inherit;">
      <span class="titular" style="font-size:18px;"><%= nombreMarca %></span>
    </a>
    <a href="/" class="nav-links" style="text-decoration:none;color:inherit;">← Todas las rutas</a>
  </div>

  <div class="hero-overlay">
    <div class="etiqueta-ruta titular">Traslado intermunicipal · Gran Canaria</div>
    <h1 class="titulo-ruta titular">
      <%= seo.origen %> <span class="acento">→</span><br><%= seo.destino %>
    </h1>
    <p class="subtitulo-ruta">Precio fijo, chofer confirmado antes de salir. Sin sorpresas en la factura.</p>
    <a href="/" class="boton-reservar">Solicitar este traslado</a>
  </div>
</div>

<div class="seccion">
  <h2>Tarifas disponibles</h2>
  <% if (precios.length > 0) { %>
  <table class="tabla-tarifas">
    <thead>
      <tr>
        <th>Categoría</th>
        <th>Pasajeros</th>
        <th>Equipaje</th>
        <th>Precio</th>
      </tr>
    </thead>
    <tbody>
      <% precios.forEach(function(p) { %>
      <tr>
        <td><strong><%= p.nombre %></strong></td>
        <td><%= p.capacidad_pasajeros %> pax</td>
        <td><%= p.capacidad_maletas %></td>
        <td>
          <% if (p.precio) { %>
            <span class="precio-fijo"><%= Number(p.precio).toFixed(0) %> €</span>
            <span class="badge-fijo">precio fijo</span>
          <% } else { %>
            <span class="consultar">A consultar</span>
          <% } %>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p style="color:var(--texto-muted);font-size:14px;">Consulta disponibilidad y precio para este traslado.</p>
  <% } %>
  <p style="margin-top:20px;">
    <a href="/" class="boton-reservar">Solicitar este traslado</a>
  </p>
</div>

<div class="seccion">
  <h2>Cómo funciona</h2>
  <div class="tres-columnas">
    <div class="tarjeta">
      <strong>1. Reserva</strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);">Solicitas el traslado con tu ruta y categoría de vehículo. Ves el precio fijo antes de confirmar.</p>
    </div>
    <div class="tarjeta">
      <strong>2. Confirmación</strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);">Un chofer acepta tu viaje y te lo confirmamos antes de que salgas de casa.</p>
    </div>
    <div class="tarjeta">
      <strong>3. Viaje</strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);">Coordinamos los detalles por WhatsApp. Tu chofer ya sabe dónde y cuándo recogerte.</p>
    </div>
  </div>
</div>

<footer><%= nombreMarca %> — Gran Canaria</footer>

<script>
// Carga el fondo de portada igual que en la página principal
var img = new Image();
img.onload = function () {
  document.getElementById('hero').style.backgroundImage = "url('/fondo-activo')";
};
img.onerror = function () {};
img.src = '/fondo-activo';
</script>

</body>
</html>
