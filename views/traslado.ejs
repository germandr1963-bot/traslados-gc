<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= seo.meta_title || (seo.origen + ' → ' + seo.destino + ' — ' + nombreMarca) %></title>

<% if (seo.meta_description) { %>
<meta name="description" content="<%= seo.meta_description %>">
<% } %>

<meta name="robots" content="<%= seo.robots_status || 'index,follow' %>">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="<%= nombreMarca %>">
<meta property="og:title" content="<%= seo.og_title || seo.meta_title || (seo.origen + ' → ' + seo.destino) %>">
<% if (seo.og_description || seo.meta_description) { %>
<meta property="og:description" content="<%= seo.og_description || seo.meta_description %>">
<% } %>
<% if (seo.canonical_url) { %>
<meta property="og:url" content="<%= seo.canonical_url %>">
<% } %>
<% if (seo.tiene_imagen) { %>
<meta property="og:image" content="<%= BASE_URL %>/ruta-imagen/<%= seo.ruta_id %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<% } else if (tieneImagenDefecto) { %>
<meta property="og:image" content="<%= BASE_URL %>/imagen-og-defecto">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<% } %>

<!-- Twitter / X (solo si está activado en los ajustes globales) -->
<% if (twitterActivo) { %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= seo.og_title || seo.meta_title || (seo.origen + ' → ' + seo.destino) %>">
<% if (seo.og_description || seo.meta_description) { %>
<meta name="twitter:description" content="<%= seo.og_description || seo.meta_description %>">
<% } %>
<% if (seo.tiene_imagen) { %>
<meta name="twitter:image" content="<%= BASE_URL %>/ruta-imagen/<%= seo.ruta_id %>">
<% } else if (tieneImagenDefecto) { %>
<meta name="twitter:image" content="<%= BASE_URL %>/imagen-og-defecto">
<% } %>
<% } %>

<!-- Canonical -->
<% if (seo.canonical_url) { %>
<link rel="canonical" href="<%= seo.canonical_url %>">
<% } %>

<!-- Datos estructurados (Schema.org) — le dicen a Google qué es exactamente
     esta página: un servicio de transporte concreto, con su precio real. -->
<script type="application/ld+json"><%- JSON.stringify(schemaTaxiService).replace(/<\/script>/gi, '<\\/script>') %></script>
<script type="application/ld+json"><%- JSON.stringify(schemaBreadcrumb).replace(/<\/script>/gi, '<\\/script>') %></script>

<!-- Hreflang: una etiqueta por cada idioma activo de esta ruta -->
<% alternates.forEach(function(alt) { %>
<link rel="alternate" hreflang="<%= alt.lang_code %>" href="<%= BASE_URL %>/<%= alt.lang_code %>/<%= SECCIONES_TRASLADO[alt.lang_code] %>/<%= alt.slug_url %>">
<% }); %>
<!-- x-default apunta siempre a la versión en español -->
<link rel="alternate" hreflang="x-default" href="<%= BASE_URL %>/es/<%= SECCIONES_TRASLADO['es'] %>/<%= seo.slug_url %>">

<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500&family=Public+Sans:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/estilos.css">
<style>
.hero {
  min-height: 420px;
  background-color: var(--charcoal);
  background-size: cover;
  background-position: center;
  display: flex;
  flex-direction: column;
  color: var(--texto-claro);
  padding: 24px 24px 60px;
}
.hero-overlay {
  position: relative;
  background: rgba(28,24,21,0.60);
  border-radius: 16px;
  padding: 36px 32px;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
}
.nav-superior {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 900px;
  margin: 0 auto 28px;
  width: 100%;
}
.nav-links { font-size: 13px; opacity: 0.7; }
.etiqueta-ruta {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: 0.65;
  margin-bottom: 8px;
}
.titulo-ruta {
  font-size: clamp(26px, 4.5vw, 42px);
  line-height: 1.1;
  margin-bottom: 14px;
}
.titulo-ruta .acento { color: var(--terracota); }
.subtitulo-ruta {
  font-size: 15px;
  opacity: 0.85;
  max-width: 440px;
  margin-bottom: 28px;
}
.boton-reservar {
  display: inline-block;
  background: var(--terracota);
  color: white;
  font-family: 'Big Shoulders Display', sans-serif;
  font-size: 16px;
  padding: 12px 28px;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.15s;
}
.boton-reservar:hover { opacity: 0.88; }
.seccion {
  max-width: 900px;
  margin: 50px auto;
  padding: 0 24px;
}
.seccion h2 {
  font-family: 'Big Shoulders Display', sans-serif;
  font-weight: 500;
  font-size: 24px;
  margin-bottom: 18px;
  color: var(--texto-oscuro);
}
.tabla-tarifas {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.tabla-tarifas th {
  background: var(--charcoal);
  color: var(--texto-claro);
  padding: 10px 14px;
  text-align: left;
  font-weight: 500;
  font-family: 'Big Shoulders Display', sans-serif;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.tabla-tarifas td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--gris-borde);
  color: var(--texto-oscuro);
}
.tabla-tarifas tr:last-child td { border-bottom: none; }
.tabla-tarifas tr:hover td { background: var(--gris-fondo); }
.precio-fijo {
  font-weight: 500;
  font-size: 16px;
  color: var(--texto-oscuro);
}
.badge-fijo {
  background: var(--oro);
  color: var(--oro-texto);
  font-size: 11px;
  font-weight: 500;
  padding: 3px 9px;
  border-radius: 10px;
  margin-left: 8px;
}
.consultar {
  color: var(--texto-muted);
  font-style: italic;
}
.tres-columnas {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
footer {
  text-align: center;
  padding: 30px;
  color: var(--texto-muted);
  font-size: 13px;
  border-top: 1px solid var(--gris-borde);
  margin-top: 40px;
}

/* ── Responsive móvil ──────────────────────────────────────────────────── */
@media (max-width: 600px) {
  .hero {
    padding: 16px 12px 40px;
    min-height: auto;
  }
  .hero-overlay {
    padding: 24px 16px;
    border-radius: 10px;
  }
  .nav-superior {
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .titulo-ruta {
    font-size: clamp(22px, 7vw, 32px);
  }
  .subtitulo-ruta {
    font-size: 14px;
    margin-bottom: 20px;
  }
  .boton-reservar {
    display: block;
    text-align: center;
    padding: 12px 20px;
  }
  .seccion {
    padding: 0 14px;
    margin: 32px auto;
  }
  .tabla-tarifas {
    font-size: 13px;
  }
  .tabla-tarifas th,
  .tabla-tarifas td {
    padding: 8px 8px;
  }
  /* En móvil muy pequeño ocultar columna equipaje */
  .tabla-tarifas th:nth-child(3),
  .tabla-tarifas td:nth-child(3) {
    display: none;
  }
  .tres-columnas {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}
</style>
</head>
<body>

<div class="hero" id="hero">
  <div class="nav-superior">
    <a href="/" style="text-decoration:none;color:inherit;">
      <span class="titular" style="font-size:18px;"><%= nombreMarca %></span>
    </a>
    <div style="display:flex;align-items:center;gap:16px;">
      <% if (alternates && alternates.length > 1) { %>
      <div style="display:flex;gap:8px;font-size:12px;">
        <% alternates.forEach(function(alt, i) { %>
          <% if (alt.lang_code === lang) { %>
            <span style="font-weight:700;text-transform:uppercase;"><%= lang %></span>
          <% } else { %>
            <a href="/<%= alt.lang_code %>/<%= SECCIONES_TRASLADO[alt.lang_code] %>/<%= alt.slug_url %>"
               style="text-decoration:none;color:inherit;opacity:0.65;text-transform:uppercase;"
               onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.65'">
              <%= alt.lang_code %>
            </a>
          <% } %>
          <% if (i < alternates.length - 1) { %><span style="opacity:0.4;">|</span><% } %>
        <% }); %>
      </div>
      <% } %>
      <a href="/" class="nav-links" style="text-decoration:none;color:inherit;"><%= t('nav_volver_rutas') %></a>
    </div>
  </div>

  <div class="hero-overlay">
    <div class="etiqueta-ruta titular"><%= t('etiqueta_categoria_ruta') %></div>
    <h1 class="titulo-ruta titular">
      <%= seo.origen %> <span class="acento">→</span><br><%= seo.destino %>
    </h1>
    <p class="subtitulo-ruta"><%= t('subtitulo_hero') %></p>
    <a href="/" class="boton-reservar"><%= t('boton_solicitar_traslado') %></a>
  </div>
</div>

<div class="seccion">
  <h2><%= t('titulo_tarifas') %></h2>
  <% if (precios.length > 0) { %>
  <table class="tabla-tarifas">
    <thead>
      <tr>
        <th><%= t('tabla_columna_categoria') %></th>
        <th><%= t('tabla_columna_pasajeros') %></th>
        <th><%= t('tabla_columna_equipaje') %></th>
        <th><%= t('tabla_columna_precio') %></th>
      </tr>
    </thead>
    <tbody>
      <% precios.forEach(function(p) { %>
      <tr>
        <td><strong><%= p.nombre %></strong></td>
        <td><%= p.capacidad_pasajeros %> <%= t('sufijo_pax') %></td>
        <td><%= p.capacidad_maletas %></td>
        <td>
          <% if (p.precio) { %>
            <span class="precio-fijo"><%= Number(p.precio).toFixed(0) %> €</span>
            <span class="badge-fijo"><%= t('badge_precio_fijo') %></span>
          <% } else { %>
            <span class="consultar"><%= t('texto_a_consultar') %></span>
          <% } %>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <p style="color:var(--texto-muted);font-size:14px;"><%= t('texto_consulta_disponibilidad') %></p>
  <% } %>
  <p style="margin-top:20px;">
    <a href="/" class="boton-reservar"><%= t('boton_solicitar_traslado') %></a>
  </p>
</div>

<div class="seccion">
  <h2><%= t('titulo_como_funciona') %></h2>
  <div class="tres-columnas">
    <div class="tarjeta">
      <strong><%= t('paso1_titulo') %></strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);"><%= t('paso1_texto') %></p>
    </div>
    <div class="tarjeta">
      <strong><%= t('paso2_titulo') %></strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);"><%= t('paso2_texto') %></p>
    </div>
    <div class="tarjeta">
      <strong><%= t('paso3_titulo') %></strong>
      <p style="margin-top:8px;font-size:14px;color:var(--texto-muted);"><%= t('paso3_texto') %></p>
    </div>
  </div>
</div>

<% if (relacionadas && relacionadas.length > 0) { %>
<div class="seccion">
  <h2><%= t('titulo_rutas_relacionadas') %> <%= seo.origen %></h2>
  <div class="tres-columnas">
    <% relacionadas.forEach(function(r) { %>
    <a href="/<%= lang %>/<%= SECCIONES_TRASLADO[lang] %>/<%= r.slug_url %>" class="tarjeta" style="text-decoration:none;color:inherit;display:block;">
      <strong><%= seo.origen %> → <%= r.destino %></strong>
    </a>
    <% }); %>
  </div>
</div>
<% } %>

<footer><%= nombreMarca %> — Gran Canaria</footer>

<script>
// Carga el fondo de portada igual que en la página principal
var img = new Image();
img.onload = function () {
  document.getElementById('hero').style.backgroundImage = "url('/fondo-activo')";
};
img.onerror = function () {};
img.src = '/fondo-activo';
</script>

</body>
</html>
